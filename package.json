{
  "name": "latex-html",
  "version": "0.1.0",
  "private": true,
  "description": "Bounded LaTeX math subset to HTML (no MathJax)",
  "type": "module",
  "scripts": {
    "build": "npm run build:cli && npm run build:browser",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:browser": "webpack --mode production",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "html-webpack-plugin": "^5.6.3",
    "prettier": "^3.5.3",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}
